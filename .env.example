# ============================================
# Sellzin CRM — Variáveis de Ambiente
# ============================================
# Copie para .env e ajuste os valores

# ── App ──
NODE_ENV=production
APP_PORT=3000
API_PORT=3001
APP_URL=http://localhost:3000
API_URL=http://localhost:3001
JWT_SECRET=trocar-por-uma-chave-segura-de-64-chars

# ── Banco de Dados ──
POSTGRES_USER=sellzin
POSTGRES_PASSWORD=sellzin_secret
POSTGRES_DB=sellzin
POSTGRES_PORT=5432
DATABASE_URL=postgresql://sellzin:sellzin_secret@postgres:5432/sellzin

# ── Redis ──
REDIS_URL=redis://redis:6379
REDIS_PORT=6379

# ── WhatsApp (Evolution API) ──
EVOLUTION_API_URL=http://evolution:8080
EVOLUTION_API_KEY=sellzin-evolution-key
EVOLUTION_PORT=8080
VPS_IP=37.27.205.228

# ── WhatsApp Business API (Meta Oficial) ──
# Configure no Meta Business Manager → WhatsApp → API Setup
# WHATSAPP_PHONE_NUMBER_ID=
# WHATSAPP_ACCESS_TOKEN=
# WHATSAPP_BUSINESS_ACCOUNT_ID=

# ── Integrações E-commerce ──
# Configuradas por tenant no painel

# ── Email (Resend) ──
RESEND_API_KEY=re_xxxxxxxxxxxx
EMAIL_FROM=noreply@sellzin.com

# ── Super Admin ──
ADMIN_EMAIL=admin@sellzin.com
ADMIN_PASSWORD=sellzin@admin2024

# ── Bull Board (opcional) ──
BULL_BOARD_PORT=3002

# ── Portainer Labels ──
# Descomente se usar Traefik com Portainer
# TRAEFIK_HOST=sellzin.seudominio.com
